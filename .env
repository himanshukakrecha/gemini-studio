# ─────────────────────────────────────────────
#  GEMINI STUDIO — Environment Variables
#  Copy this file to .env and fill in values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# 1. Gemini API Key
#    Get free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_your_key_here

# 2. Cloudinary (free tier — 25 GB/month)
#    Dashboard: https://cloudinary.com/console
#    Cloud Name = top of dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
#    Upload Preset = Settings → Upload → Add Upload Preset → set to UNSIGNED
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# 3. Instagram Graph API
#    Business/Creator account required
#    Get token: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx_your_long_lived_token
#    Account ID: GET https://graph.facebook.com/me/accounts?access_token=YOUR_TOKEN
INSTAGRAM_ACCOUNT_ID=17841000000000000

# 4. Server config (optional)
PORT=3000
NODE_ENV=production
